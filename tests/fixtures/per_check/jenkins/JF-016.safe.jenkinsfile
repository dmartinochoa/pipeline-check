pipeline {
  agent any
  stages {
    stage('Setup') {
      steps {
        sh '''
          curl -fsSL https://example.com/install.sh -o install.sh
          sha256sum -c install.sh.sha256
          bash install.sh
        '''
      }
    }
    stage('Build') {
      steps {
        sh 'make build'
      }
    }
  }
}
