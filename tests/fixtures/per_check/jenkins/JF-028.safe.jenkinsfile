pipeline {
  agent { label 'build' }
  stages {
    stage('Build') {
      steps {
        sh 'docker build -t app:$BUILD_TAG .'
        sh 'docker push app:$BUILD_TAG'
        sh 'cosign attest --yes --predicate provenance.intoto.jsonl --type slsaprovenance app:$BUILD_TAG'
        sh 'cosign sign --yes app:$BUILD_TAG'
      }
    }
  }
}
