# Realistic insecure Dockerfile exhibiting every DF-* failure mode.
# Modelled on patterns commonly seen in public repos, used as a fixture
# to assert the scanner flags every rule in one sweep.

# DF-001: FROM uses a floating tag, not a sha256 digest.
FROM python:3.12-slim

# DF-006: ENV / ARG carries credential-shaped literals. Values are
# obvious placeholders so GitHub Push Protection / secret scanners
# don't false-positive on the fixture itself; DF-006 fires on the
# credential-shaped KEY name + any non-empty literal value, so the
# placeholder still triggers it the same way a real secret would.
ENV API_KEY=EXAMPLE-FAKE-KEY-DO-NOT-USE
ENV AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
ARG DATABASE_PASSWORD=EXAMPLE-FAKE-PASSWORD

# DF-014: WORKDIR set to a system / kernel filesystem path. Subsequent
# COPY / RUN writes resolve against /etc, putting writes into admin-
# only configuration directories.
WORKDIR /etc/app-config

# DF-017: ENV PATH prepends a world-writable directory (/tmp). Anyone
# inside the container can drop a binary there to shadow system bins.
# DF-018: a later RUN below chowns /etc/myapp, granting the runtime
# user write access to a system directory.
ENV PATH=/tmp/bin:$PATH

# DF-003: ADD pulls a remote URL without --checksum= integrity flag.
ADD https://example.com/internal/helper.tar.gz /opt/

# DF-009: ADD used where COPY would suffice (local file, no URL or
# tarball auto-extract use case).
ADD ./config.json /opt/config.json

# DF-004: RUN curl-piped to bash without checksum verification.
# DF-005: RUN uses dangerous shell-eval idiom (eval on a variable).
# DF-008: RUN invokes docker --privileged inside the build.
# DF-010: apt-get dist-upgrade pulls unknown package versions.
# DF-011: apt-get install without same-layer cache cleanup.
# DF-012: sudo invocation inside RUN.
# DF-015: chmod 777 grants world-writable permissions.
RUN apt-get update && apt-get dist-upgrade -y && \
    apt-get install -y curl wget && \
    sudo chown -R nobody /opt && \
    chmod 777 /opt/shared && \
    chown -R nobody /etc/myapp && \
    curl -fsSL https://example.com/install.sh | bash && \
    eval "$BUILD_CMD" && \
    docker run --privileged builder-image make all

COPY . .

# DF-013: EXPOSE declares SSH port — containers should not run sshd.
EXPOSE 22

# DF-002: no USER directive — image runs as root.
# DF-007: no HEALTHCHECK directive.
# DF-016: no LABEL line declares OCI provenance fields
# (``org.opencontainers.image.source`` / ``image.revision``).

CMD ["python", "app.py"]
